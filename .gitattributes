# Default: normalize to LF in the repo, convert on checkout per OS
* text=auto

# Rust
*.rs    text eol=lf
*.toml  text eol=lf
*.lock  text eol=lf

# Docs & config
*.md    text eol=lf
*.json  text eol=lf

# Scripts — enforce native line endings per platform
*.sh    text eol=lf
*.ps1   text eol=crlf

# Repo meta
.gitignore      text eol=lf
.gitattributes  text eol=lf
LICENSE         text eol=lf